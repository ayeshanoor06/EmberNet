<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/coal"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/screen_padding">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/mesh_title"
            android:textColor="@color/cream"
            android:textSize="@dimen/text_title"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="@dimen/space_lg"
            android:layout_marginBottom="@dimen/space_xs" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bluetooth LE + Wi-Fi Direct"
            android:textColor="@color/warm_gray"
            android:textSize="@dimen/text_sm"
            android:layout_marginBottom="@dimen/space_lg" />

        <!-- Start mesh button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_start_mesh"
            style="@style/Widget.EmberNet.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_md"
            android:text="Start mesh receiver" />

        <!-- Status card -->
        <androidx.cardview.widget.CardView
            style="@style/Widget.EmberNet.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_md">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="@dimen/card_padding"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/mesh_status_dot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/circle_dot_red"
                    android:layout_marginEnd="@dimen/space_sm" />

                <TextView
                    android:id="@+id/mesh_status_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/mesh_status_off"
                    android:textColor="@color/cream"
                    android:textSize="@dimen/text_body"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/mesh_range"
                    android:textColor="@color/warm_gray"
                    android:textSize="@dimen/text_xs"
                    android:fontFamily="monospace" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Stats grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/space_md">

            <androidx.cardview.widget.CardView
                style="@style/Widget.EmberNet.Card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/space_sm">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BLE"
                        android:textColor="@color/warm_gray"
                        android:textSize="@dimen/text_xs"
                        android:letterSpacing="0.1" />
                    <TextView
                        android:id="@+id/mesh_peer_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/signal_blue"
                        android:textSize="@dimen/text_display"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                style="@style/Widget.EmberNet.Card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/space_sm"
                android:layout_marginEnd="@dimen/space_sm">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="WI-FI"
                        android:textColor="@color/warm_gray"
                        android:textSize="@dimen/text_xs"
                        android:letterSpacing="0.1" />
                    <TextView
                        android:id="@+id/mesh_wifi_peer_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/signal_green"
                        android:textSize="@dimen/text_display"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                style="@style/Widget.EmberNet.Card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/space_sm">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding"
                    android:gravity="center">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RELAYED"
                        android:textColor="@color/warm_gray"
                        android:textSize="@dimen/text_xs"
                        android:letterSpacing="0.1" />
                    <TextView
                        android:id="@+id/mesh_relay_count_val"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/signal_yellow"
                        android:textSize="@dimen/text_display"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- Radio pills -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/space_lg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mesh_bt"
                android:textColor="@color/signal_blue"
                android:textSize="@dimen/text_xs"
                android:fontFamily="monospace"
                android:background="@drawable/badge_background_green"
                android:paddingStart="@dimen/space_sm"
                android:paddingEnd="@dimen/space_sm"
                android:paddingTop="@dimen/space_xs"
                android:paddingBottom="@dimen/space_xs"
                android:layout_marginEnd="@dimen/space_sm" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mesh_wifi"
                android:textColor="@color/signal_green"
                android:textSize="@dimen/text_xs"
                android:fontFamily="monospace"
                android:background="@drawable/badge_background_green"
                android:paddingStart="@dimen/space_sm"
                android:paddingEnd="@dimen/space_sm"
                android:paddingTop="@dimen/space_xs"
                android:paddingBottom="@dimen/space_xs" />

        </LinearLayout>

        <!-- How it works -->
        <androidx.cardview.widget.CardView
            style="@style/Widget.EmberNet.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_md">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HOW MESH RELAY WORKS"
                    android:textColor="@color/warm_gray"
                    android:textSize="@dimen/text_xs"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="@dimen/space_sm" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="When you send SOS, your phone broadcasts over Bluetooth LE. Any nearby phone with EmberNet automatically receives and re-broadcasts your message to the next device — creating a chain that reaches help even without cell signal."
                    android:textColor="@color/cream_dim"
                    android:textSize="@dimen/text_sm"
                    android:lineSpacingMultiplier="1.5" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Pre-flight demo button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_preflight"
            style="@style/Widget.EmberNet.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_md"
            android:text="Pre-flight checklist" />

        <!-- BLE diagnostics -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_ble_check"
            style="@style/Widget.EmberNet.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_sm"
            android:text="Run BLE diagnostics" />

        <TextView
            android:id="@+id/ble_diag_output"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/space_xl"
            android:textColor="@color/cream_dim"
            android:textSize="@dimen/text_xs"
            android:fontFamily="monospace"
            android:lineSpacingMultiplier="1.6"
            android:text="" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>