<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/ash"
    android:paddingTop="@dimen/space_sm">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="@color/warm_gray"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="@dimen/space_md" />

    <!-- Alert header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:gravity="center_vertical"
        android:layout_marginBottom="@dimen/space_md">

        <View
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/circle_dot_red"
            android:layout_marginEnd="@dimen/space_sm" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SOS RECEIVED"
            android:textColor="@color/ember"
            android:textSize="@dimen/text_title"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1" />

        <TextView
            android:id="@+id/sos_alert_device_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Device A"
            android:textColor="@color/warm_gray"
            android:textSize="@dimen/text_xs"
            android:fontFamily="monospace" />

    </LinearLayout>

    <!-- Detail grid -->
    <androidx.gridlayout.widget.GridLayout
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/screen_padding"
        android:layout_marginEnd="@dimen/screen_padding"
        android:layout_marginBottom="@dimen/space_md"
        app:columnCount="2"
        app:rowCount="3">

        <!-- Coords label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LOCATION"
            android:textColor="@color/warm_gray"
            android:textSize="@dimen/text_xs"
            android:letterSpacing="0.1"
            android:layout_marginBottom="2dp"
            app:layout_column="0"
            app:layout_row="0" />

        <!-- Battery label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BATTERY"
            android:textColor="@color/warm_gray"
            android:textSize="@dimen/text_xs"
            android:letterSpacing="0.1"
            android:layout_marginBottom="2dp"
            app:layout_column="1"
            app:layout_row="0" />

        <!-- Coords value -->
        <TextView
            android:id="@+id/sos_alert_coords"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="33.6938°N  73.0651°E"
            android:textColor="@color/cream"
            android:textSize="@dimen/text_sm"
            android:fontFamily="monospace"
            android:layout_marginBottom="@dimen/space_md"
            app:layout_column="0"
            app:layout_row="1" />

        <!-- Battery value -->
        <TextView
            android:id="@+id/sos_alert_battery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="72%"
            android:textColor="@color/signal_green"
            android:textSize="@dimen/text_sm"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="@dimen/space_md"
            app:layout_column="1"
            app:layout_row="1" />

        <!-- Hops label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MESH HOPS"
            android:textColor="@color/warm_gray"
            android:textSize="@dimen/text_xs"
            android:letterSpacing="0.1"
            android:layout_marginBottom="2dp"
            app:layout_column="0"
            app:layout_row="2" />

        <!-- Time label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RECEIVED AT"
            android:textColor="@color/warm_gray"
            android:textSize="@dimen/text_xs"
            android:letterSpacing="0.1"
            android:layout_marginBottom="2dp"
            app:layout_column="1"
            app:layout_row="2" />

    </androidx.gridlayout.widget.GridLayout>

    <!-- Hops + time values row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:layout_marginBottom="@dimen/space_lg">

        <TextView
            android:id="@+id/sos_alert_hops"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="2 hops"
            android:textColor="@color/signal_yellow"
            android:textSize="@dimen/text_sm"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/sos_alert_time"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="14:32:08"
            android:textColor="@color/cream"
            android:textSize="@dimen/text_sm"
            android:fontFamily="monospace" />

    </LinearLayout>

    <!-- Dismiss button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_dismiss_alert"
        style="@style/Widget.EmberNet.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/screen_padding"
        android:layout_marginEnd="@dimen/screen_padding"
        android:layout_marginBottom="@dimen/space_xl"
        android:text="@string/alert_dismiss" />

</LinearLayout>