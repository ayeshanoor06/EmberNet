<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/ash"
    android:paddingTop="@dimen/space_sm">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="@color/warm_gray"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="@dimen/space_md" />

    <!-- Zone type badge + name row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:gravity="center_vertical"
        android:layout_marginBottom="@dimen/space_sm">

        <TextView
            android:id="@+id/zone_type_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Medical"
            android:textColor="@color/signal_green"
            android:textSize="@dimen/text_xs"
            android:fontFamily="monospace"
            android:background="@drawable/badge_background_green"
            android:paddingStart="@dimen/space_sm"
            android:paddingEnd="@dimen/space_sm"
            android:paddingTop="@dimen/space_xs"
            android:paddingBottom="@dimen/space_xs"
            android:layout_marginEnd="@dimen/space_sm" />

        <TextView
            android:id="@+id/zone_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="PIMS Hospital"
            android:textColor="@color/cream"
            android:textSize="@dimen/text_title"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>

    <!-- Coordinates row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:gravity="center_vertical"
        android:layout_marginBottom="@dimen/space_md">

        <TextView
            android:id="@+id/zone_coords"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="33.7215°N  73.0706°E"
            android:textColor="@color/warm_gray"
            android:textSize="@dimen/text_xs"
            android:fontFamily="monospace" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/zone_distance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1.2 km away"
            android:textColor="@color/ember"
            android:textSize="@dimen/text_sm"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/divider"
        android:layout_marginBottom="@dimen/space_md" />

    <!-- Status row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:layout_marginBottom="@dimen/space_lg">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STATUS"
                android:textColor="@color/warm_gray"
                android:textSize="@dimen/text_xs"
                android:letterSpacing="0.1"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/zone_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Open"
                android:textColor="@color/signal_green"
                android:textSize="@dimen/text_body"
                android:fontFamily="sans-serif-medium" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CAPACITY"
                android:textColor="@color/warm_gray"
                android:textSize="@dimen/text_xs"
                android:letterSpacing="0.1"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/zone_capacity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="500 people"
                android:textColor="@color/cream"
                android:textSize="@dimen/text_body"
                android:fontFamily="sans-serif-medium" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VERIFIED"
                android:textColor="@color/warm_gray"
                android:textSize="@dimen/text_xs"
                android:letterSpacing="0.1"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/zone_verified"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Yes"
                android:textColor="@color/signal_green"
                android:textSize="@dimen/text_body"
                android:fontFamily="sans-serif-medium" />

        </LinearLayout>

    </LinearLayout>

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:paddingBottom="@dimen/space_xl">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_navigate_zone"
            style="@style/Widget.EmberNet.Button.Primary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Navigate" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_share_zone"
            style="@style/Widget.EmberNet.Button.Outlined"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="Share via mesh" />

    </LinearLayout>

</LinearLayout>