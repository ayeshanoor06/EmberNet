<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/coal">

    <!-- OSMDroid map — fills the entire screen -->
    <org.osmdroid.views.MapView
        android:id="@+id/map_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clickable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Top status bar overlay -->
    <androidx.cardview.widget.CardView
        android:id="@+id/map_status_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/screen_padding"
        android:layout_marginEnd="@dimen/screen_padding"
        android:layout_marginTop="@dimen/space_lg"
        app:cardBackgroundColor="@color/ash"
        app:cardCornerRadius="@dimen/radius_md"
        app:cardElevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="@dimen/card_padding"
            android:gravity="center_vertical">

            <!-- Map status dot -->
            <View
                android:id="@+id/map_status_dot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/circle_dot"
                android:layout_marginEnd="@dimen/space_sm" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/map_status_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/map_title"
                    android:textColor="@color/cream"
                    android:textSize="@dimen/text_body"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/map_coords_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Acquiring GPS..."
                    android:textColor="@color/warm_gray"
                    android:textSize="@dimen/text_xs"
                    android:fontFamily="monospace" />

            </LinearLayout>

            <!-- My location button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_my_location"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:icon="@drawable/ic_map"
                app:iconTint="@color/ember"
                app:iconSize="20dp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Download offline map button — bottom of screen -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_download_map"
        style="@style/Widget.EmberNet.Button.Primary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/screen_padding"
        android:layout_marginEnd="@dimen/screen_padding"
        android:layout_marginBottom="@dimen/space_lg"
        android:text="@string/download_map"
        android:padding="@dimen/space_md"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>