<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer pulse ring -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#334B9EFF" />
            <size android:width="40dp" android:height="40dp" />
        </shape>
    </item>

    <!-- Inner solid dot -->
    <item
        android:top="10dp"
        android:bottom="10dp"
        android:left="10dp"
        android:right="10dp">
        <shape android:shape="oval">
            <solid android:color="@color/signal_blue" />
            <stroke android:width="2dp" android:color="@color/cream" />
            <size android:width="20dp" android:height="20dp" />
        </shape>
    </item>

</layer-list>