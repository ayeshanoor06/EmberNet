<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer alert ring -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#55E8521A" />
            <size android:width="44dp" android:height="44dp" />
        </shape>
    </item>

    <!-- Inner ember dot -->
    <item
        android:top="10dp"
        android:bottom="10dp"
        android:left="10dp"
        android:right="10dp">
        <shape android:shape="oval">
            <solid android:color="@color/ember" />
            <stroke android:width="2dp" android:color="@color/cream" />
            <size android:width="24dp" android:height="24dp" />
        </shape>
    </item>

</layer-list>